# Build the Candela server
FROM golang:1.23-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o candela-server ./cmd/candela-server

# Runtime
FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /build/candela-server /usr/local/bin/candela-server

EXPOSE 8080
ENTRYPOINT ["candela-server"]
