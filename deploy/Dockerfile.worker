# Build the Candela worker
FROM golang:1.26-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build -o candela-worker ./cmd/candela-worker

# Runtime
FROM alpine:3.20
RUN apk add --no-cache ca-certificates
COPY --from=builder /build/candela-worker /usr/local/bin/candela-worker

ENTRYPOINT ["candela-worker"]
